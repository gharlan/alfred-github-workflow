#!/usr/bin/env php
<?php

$dir = dirname(__DIR__);

require $dir . '/src/workflow.php';

$plist = $dir . '/info.plist';

exec(sprintf('/usr/libexec/PlistBuddy -c "Set :version %s" %s', Workflow::VERSION, escapeshellarg($plist)));

$changelog = file_get_contents($dir . '/CHANGELOG.md');
assert(is_string($changelog));
$changelog = strtr($changelog, [
    '\\' => '\\\\',
    '"' => '\\"',
    "'" => "\\'",
    "\n" => '\n',
]);
exec(sprintf('/usr/libexec/PlistBuddy -c %s %s', escapeshellarg('Set :readme "' . $changelog . '"'), escapeshellarg($plist)));

$zipFile = $dir . '/github.zip';
if (file_exists($zipFile)) {
    unlink($zipFile);
}

$zip = new PharData($zipFile);

$cleanedPlist = shell_exec(sprintf('%s < %s', escapeshellarg($dir . '/bin/info-plist-clean'), escapeshellarg($plist)));
assert(is_string($cleanedPlist) && '' !== $cleanedPlist);
$zip->addFromString('info.plist', $cleanedPlist);

foreach ([
    'CHANGELOG.md',
    'icon.png',
    'LICENSE',
    'README.md',
] as $file) {
    $zip->addFile($dir . '/' . $file, $file);
}

foreach (glob($dir . '/src/*.php') as $path) { // @phpstan-ignore foreach.nonIterable
    $zip->addFile($path, 'src/' . basename($path));
}
foreach (glob($dir . '/icons/*.png') as $path) { // @phpstan-ignore foreach.nonIterable
    $zip->addFile($path, 'icons/' . basename($path));
}

$zip->compressFiles(Phar::GZ);

$workflow = $dir . '/github.alfredworkflow';
if (file_exists($workflow)) {
    unlink($workflow);
}
rename($zipFile, $workflow);
